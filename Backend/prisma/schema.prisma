generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId        String         @id @default(uuid())
  name          String
  
  // 1 to 1 relation with Calendar
  calendar      Calendar?
  
  // Many-to-many: the group meetings this user participates in
  groupMeetings GroupMeeting[]
}

model Calendar {
  id            String         @id @default(uuid())
  
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  
  // Composition: Calendar has an array of Appointments
  appointments  Appointment[]
}

model Appointment {
  id            String         @id @default(uuid())
  name          String
  location      String
  startTime     DateTime
  endTime       DateTime
  
  // Belongs to Calendar
  calendarId    String
  calendar      Calendar       @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  
  // Composition: Appointment has an array of Reminders
  reminders     Reminder[]
  
  // 1:1 Inheritance mapping
  groupMeeting  GroupMeeting?
}

model Reminder {
  id            String      @id @default(uuid())
  remindAt      DateTime
  
  // Belongs to Appointment
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model GroupMeeting {
  id            String      @id @default(uuid())
  
  // 1:1 Relation mapping "inheritance" from Appointment
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  
  // Association: Participants (0..* users)
  participants  User[]
}

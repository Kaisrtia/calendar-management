generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId        String         @id @default(uuid())
  name          String
  
  // 1 to 1 relation with Calendar
  calendar      Calendar?
  
  // Primary controller for meetings owned by this user
  ownedGroupMeetings GroupMeeting[] @relation("MeetingOwner")

  // Explicit membership relation, including per-user soft delete state
  groupMeetingParticipants GroupMeetingParticipant[]
}

model Calendar {
  id            String         @id @default(uuid())
  
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  
  // Composition: Calendar has an array of Appointments
  appointments  Appointment[]
}

model Appointment {
  id            String         @id @default(uuid())
  name          String
  location      String
  startTime     DateTime
  endTime       DateTime
  
  // Belongs to Calendar
  calendarId    String
  calendar      Calendar       @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  
  // Composition: Appointment has an array of Reminders
  reminders     Reminder[]
  
  // 1:1 Inheritance mapping
  groupMeeting  GroupMeeting?
}

model Reminder {
  id            String      @id @default(uuid())
  remindAt      DateTime
  
  // Belongs to Appointment
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model GroupMeeting {
  id            String      @id @default(uuid())
  ownerId       String
  deletedAt     DateTime?
  
  // 1:1 Relation mapping "inheritance" from Appointment
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // The owner is the primary controller for create/update/delete.
  owner         User        @relation("MeetingOwner", fields: [ownerId], references: [userId], onDelete: Cascade)
  
  // Association: Participants (0..*) with individual soft delete state
  participants  GroupMeetingParticipant[]
}

model GroupMeetingParticipant {
  id             String       @id @default(uuid())
  groupMeetingId String
  userId         String
  deletedAt      DateTime?

  groupMeeting   GroupMeeting @relation(fields: [groupMeetingId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([groupMeetingId, userId])
}
